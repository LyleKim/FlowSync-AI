# APP_URL: The URL where this applet is hosted.
APP_URL="http://localhost:3000"

# GROQ_API_KEY: Required for Groq AI checklist generation API.
GROQ_API_KEY="GROQ_API_KEY"

# Django
DJANGO_SECRET_KEY="django-insecure-flowsync-ai-key-development-only"
DEBUG="True"

# MySQL Database (defaults match docker-compose.yml)
DB_NAME="DB_NAME"
DB_USER="DB_USER"
DB_PASSWORD="DB_PASSWORD"
DB_HOST="127.0.0.1"
DB_PORT="3306"

ALLOWED_HOSTS="localhost,127.0.0.1"